{
  "expo": {
    "name": "NAFA Marché Connect",
    "slug": "nafa-market-connect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/branding/app-icon-v2.svg",
    "scheme": "nafa",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/branding/splash-light.svg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nafa.market.connect",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/app-icon-v2.svg",
        "backgroundColor": "#1a472a"
      },
      "package": "com.nafa.market.connect"
    },
    "web": {
      "favicon": "./assets/branding/logo-mark-v2.svg"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/",
          "headOrigin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
